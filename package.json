{
	"name": "termheat",
	"version": "1.0.0",
	"description": "🔥 Animated terminal heatmap of your GitHub contributions — zero auth, zero config, npx and done.",
	"type": "module",
	"bin": {
		"termheat": "bin/termheat.js"
	},
	"files": [
		"dist",
		"bin"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "bun run src/index.tsx",
		"dev:self": "bun run src/index.tsx moeen-mahmud",
		"build:node": "bun build src/index.tsx --target=node --outdir=dist --minify",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"prepare": "bunx husky",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"type-check": "bunx tsc --noEmit",
		"changeset": "changeset",
		"release": "bun run build:node && changeset publish"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/moeen-mahmud/termheat.git"
	},
	"homepage": "https://github.com/moeen-mahmud/termheat#readme",
	"bugs": "https://github.com/moeen-mahmud/termheat/issues",
	"author": {
		"email": "moeen.mahmud007@gmail.com",
		"name": "Moeen Mahmud"
	},
	"license": "MIT",
	"keywords": [
		"github",
		"contributions",
		"heatmap",
		"streak",
		"commit-graph",
		"terminal",
		"cli",
		"tui",
		"ink",
		"productivity"
	],
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/bun": "latest",
		"@types/node": "latest",
		"@types/react": "^19.2.17",
		"react-devtools-core": "latest",
		"typescript": "^5",
		"@biomejs/biome": "^2.4.13",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"lint-staged": "latest"
	},
	"dependencies": {
		"ink": "^7.1.0",
		"react": "^19.2.7"
	}
}
